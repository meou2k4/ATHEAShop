# Database (Supabase hoặc bất kỳ PostgreSQL nào)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/fashionshop?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# Cloudinary (đăng ký miễn phí tại cloudinary.com)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Email (dùng Gmail SMTP - tạo App Password tại myaccount.google.com)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_gmail_app_password"
EMAIL_FROM="ATHEA FashionShop <your_email@gmail.com>"

# Server
PORT=7299
